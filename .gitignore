*.pyc

# Keep private campaign data local by default.
campaigns/
characters/
archive/
docs/imported-conversations/

# Generated comic outputs are usually based on private scenes.
**/visual-drafts/
**/*.png
**/*.jpg
**/*.jpeg
**/*.webp

# Keep public templates tracked.
!campaign-template/
!campaign-template/**
!templates/
!templates/**

# Explicit public areas for cleared examples, generated comics, and public datasets.
!examples/
!examples/**
!public-comics/
!public-comics/**
!datasets/
!datasets/**
